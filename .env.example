# === Общие (один пароль БД на Pi и локально) ===
POSTGRES_USER=roster
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=roster

JWT_SECRET=change_me_long_random_secret
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,https://medicine.greemlab.ru
EXPIRY_WARN_DAYS=30

# Яндекс OAuth: https://oauth.yandex.ru — добавить Redirect URI:
#   http://localhost:5173/api/auth/yandex/callback
#   https://medicine.greemlab.ru/api/auth/yandex/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI_LOCAL=http://localhost:5173/api/auth/yandex/callback
YANDEX_REDIRECT_URI_PROD=https://medicine.greemlab.ru/api/auth/yandex/callback

# === B3 (Pi): файл .env на сервере, docker compose up -d ===
# DATABASE_URL задаёт docker-compose.yml (хост db), эту строку можно не указывать:
# DATABASE_URL=postgresql://roster:change_me_db_password@db:5432/roster

# === Mac: локальный Docker (рекомендуется) ===
# Скопируйте .env с Pi (те же POSTGRES_PASSWORD и JWT_SECRET).
# Первый раз: ./scripts/internal/sync-db-from-pi.sh
# Стек:       ./scripts/internal/dev-stack.sh up
# UI:         ./scripts/dev.sh
#
# DATABASE_URL для scripts/internal/import.sh (локальная БД в Docker):
# DATABASE_URL=postgresql://roster:change_me_db_password@127.0.0.1:5432/roster

# SSH на B3 (после ./scripts/setup/ssh-key.sh удобнее roster-b3)
# PI_SSH=greem4@192.168.31.96
# PI_SSH=roster-b3

# === Ноутбук вне дома (опционально) ===
# ROSTER_REMOTE_API_URL=https://medicine.greemlab.ru
# ROSTER_VPS_SSH=root@176.12.65.86
# ROSTER_VPS_PI_SSH_PORT=22022
