# === Общие (один пароль БД на B3 и для туннеля с Mac) ===
POSTGRES_USER=roster
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=roster

JWT_SECRET=change_me_long_random_secret
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,https://medicine.greemlab.ru
EXPIRY_WARN_DAYS=30

# === B3 (Pi): файл .env на сервере, docker compose up -d ===
# DATABASE_URL задаёт docker-compose.yml (хост db), эту строку можно не указывать:
# DATABASE_URL=postgresql://roster:change_me_db_password@db:5432/roster

# === Mac (локальная разработка): сначала scripts/db-tunnel.sh ===
# DATABASE_URL=postgresql://roster:change_me_db_password@127.0.0.1:5432/roster
#
# Если API в Docker локально (docker compose -f docker-compose.local.yml):
# DATABASE_URL=postgresql://roster:change_me_db_password@host.docker.internal:5432/roster

# SSH на B3 (после ./scripts/setup-ssh-key.sh удобнее roster-b3)
# PI_SSH=greem4@192.168.31.96
# PI_SSH=roster-b3

# === Ноутбук вне дома (опционально) ===
# ROSTER_REMOTE_API_URL=https://medicine.greemlab.ru
# ROSTER_VPS_SSH=root@176.12.65.86
# ROSTER_VPS_PI_SSH_PORT=22022
# Один раз дома: ./scripts/setup-vps-dev-ssh.sh — потом db-tunnel-vps.sh / dev-local.sh из интернета
